<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Conscripts.Views.RegistrationLayout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Conscripts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer x:Name="RegistrationScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
        <StackPanel Orientation="Vertical" Margin="40,32,40,32" Spacing="0" MaxWidth="480" HorizontalAlignment="Center">

            <Grid Margin="0,0,0,24" HorizontalAlignment="Center">
                <Image Height="72" Width="72" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image.Source>
                        <BitmapImage UriSource="/Assets/Conscripts_Placeholder.png" DecodePixelType="Logical" DecodePixelHeight="144"/>
                    </Image.Source>
                </Image>
                <Image Height="64" Width="64" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image.Source>
                        <BitmapImage UriSource="/Assets/Conscripts_Logo.png" DecodePixelType="Logical" DecodePixelHeight="128"/>
                    </Image.Source>
                </Image>
            </Grid>

            <TextBlock x:Uid="RegistrationWelcomeTitleTextBlock" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Uid="RegistrationWelcomeSubtitleTextBlock" FontSize="14" Opacity="0.7" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,32"/>

            <TextBlock x:Uid="RegistrationNameLabelTextBlock" FontSize="13" FontWeight="Medium" Margin="0,0,0,8"/>
            <TextBox x:Name="RegistrationNameTextBox"
                     x:Uid="RegistrationNameTextBox"
                     FontSize="14"
                     Margin="0,0,0,8"
                     MaxLength="64"
                     KeyDown="RegistrationNameTextBox_KeyDown"/>
            <TextBlock x:Name="RegistrationNameErrorTextBlock"
                       x:Uid="RegistrationNameErrorTextBlock"
                       FontSize="12"
                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                       Margin="0,0,0,0"
                       Visibility="Collapsed"/>

            <Button x:Name="RegistrationGetStartedButton"
                    x:Uid="RegistrationGetStartedButton"
                    HorizontalAlignment="Stretch"
                    Margin="0,24,0,0"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="OnClickGetStarted"/>

            <HyperlinkButton x:Uid="RegistrationSkipHyperlinkButton"
                             HorizontalAlignment="Center"
                             Margin="0,8,0,0"
                             Click="OnClickSkip"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
